# SRT SLURM Configuration for GB300-CW

default_account: "cw-sup"
default_partition: "all"
default_time_limit: "8:00:00"

gpus_per_node: 4
network_interface: ""

srtctl_root: "/mnt/home/ppbhatt500/disagg_runs/dsv4_sglang_4p_4d/srt-slurm"

default_mounts:
  /mnt/vast/dynamo-wheels-cache: /configs/dynamo-wheels
  /mnt/vast/ai-perf-cache: /aiperf_mmap_cache
  /mnt/home: /mnt/home
  /mnt/vast: /mnt/vast

model_paths:
  dspro: "/mnt/vast/models/dsv4"
  dsv4-pro: "/mnt/vast/models/dsv4"
  # Our hand-rolled DSV4 sglang recipes use 
  # (matches the alias in launch_gb200-nv.sh's srtslurm.yaml). Without
  # this entry srtctl preflight rejects with "Model 'deepseek-v4-pro'
  # is not a local model path and is not defined in srtslurm.yaml
  # model_paths".
  deepseek-v4-pro: "/mnt/vast/models/dsv4"
  # GLM-5 FP8 sglang recipes use .
  glm-5-fp8: "/mnt/vast/models/dsv4"
containers:
  dynamo-trtllm: /mnt/vast/squash_dupe/lmsysorg_sglang_nightly-dev-cu13-20260602-98a1b58c_arm64.sqsh
  dynamo-sglang: /mnt/vast/squash_dupe/lmsysorg_sglang_nightly-dev-cu13-20260602-98a1b58c_arm64.sqsh
  dynamo-vllm: /mnt/vast/squash_dupe/lmsysorg_sglang_nightly-dev-cu13-20260602-98a1b58c_arm64.sqsh
  dspro-0426: /mnt/vast/squash_dupe/lmsysorg_sglang_nightly-dev-cu13-20260602-98a1b58c_arm64.sqsh
  dspro-0426-nixl: /mnt/vast/squash_dupe/lmsysorg_sglang_nightly-dev-cu13-20260602-98a1b58c_arm64.sqsh
  dsv4-grace-blackwell: /mnt/vast/squash_dupe/lmsysorg_sglang_nightly-dev-cu13-20260602-98a1b58c_arm64.sqsh
  "lmsysorg/sglang:nightly-dev-cu13-20260602-98a1b58c": /mnt/vast/squash_dupe/lmsysorg_sglang_nightly-dev-cu13-20260602-98a1b58c_arm64.sqsh
  nginx: /mnt/vast/squash_dupe/nginx_1.27.4_arm64.sqsh
  nginx-sqsh: /mnt/vast/squash_dupe/nginx_1.27.4_arm64.sqsh
# Use one contiguous CW segment for the full allocation. This is a
# cluster-level setting, not a recipe overlay; the copied recipe files
# stay byte-identical to the pinned upstream commit.
use_segment_sbatch_directive: true
# Cluster-wide bash preamble — runs before every container srun. Raises
# NOFILE so the dynamo frontend / sglang servers can accept high
# concurrency (8192 in the 7p1d sweep) without EMFILE / "too many open
# files". Mirrors what 
# already uses for manual runs on this cluster.
default_bash_preamble: "ulimit -n 1048576 && ulimit -a"
